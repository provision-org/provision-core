# =============================================================================
# Provision — Open-source AI agent deployment platform
# =============================================================================
# Copy this file to .env and fill in the required values.
# Run `php artisan key:generate` to set APP_KEY.
# =============================================================================

# --- App ---
APP_NAME=Provision
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# --- Database ---
DB_CONNECTION=sqlite

# --- Cache / Queue / Session (Redis, provided by Docker Compose) ---
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
REDIS_HOST=redis
REDIS_PORT=6379

# --- LLM Provider ---
# OpenRouter management key — Provision creates per-team sub-keys automatically.
# Get one at https://openrouter.ai/keys
OPENROUTER_PROVISIONING_API_KEY=

# --- Agent Runtime ---
CLOUD_PROVIDER=docker
PROVISION_DOCKER_CONTAINER=provision-agent-runtime-1
# HARNESS_TYPE=openclaw

# --- Cloud Provider (optional, for remote server deployment) ---
# Set ENABLE_CLOUD_PROVIDER_SELECTION=true to let users choose per-team.
# Only providers with configured API tokens will appear in the selector.
# ENABLE_CLOUD_PROVIDER_SELECTION=true
# HETZNER_API_TOKEN=
# DIGITALOCEAN_API_TOKEN=
# LINODE_API_KEY=

# --- Email Module (optional) ---
# MAILBOXKIT_API_KEY=
# MAILBOXKIT_EMAIL_DOMAIN=


# --- Admin Access (Telescope & Horizon dashboards) ---
# TELESCOPE_ADMIN_EMAILS=admin@example.com
# HORIZON_ADMIN_EMAILS=admin@example.com

# --- Mail (defaults to log driver) ---
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Vite ---
VITE_APP_NAME="${APP_NAME}"
